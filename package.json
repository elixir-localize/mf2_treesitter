{
  "name": "tree-sitter-mf2",
  "version": "0.1.0",
  "description": "tree-sitter grammar for ICU MessageFormat 2.0 (MF2) messages",
  "keywords": [
    "parser",
    "lexer",
    "tree-sitter",
    "mf2",
    "messageformat",
    "icu",
    "l10n",
    "i18n"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/elixir-localize/mf2_treesitter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elixir-localize/mf2_treesitter.git"
  },
  "bugs": {
    "url": "https://github.com/elixir-localize/mf2_treesitter/issues"
  },
  "main": "bindings/node",
  "types": "bindings/node/index.d.ts",
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*.scm",
    "src/**/*.c",
    "src/**/*.h",
    "src/**/*.json",
    "wasm/*.wasm",
    "tree-sitter.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "generate": "tree-sitter generate",
    "test": "tree-sitter test && node test/conformance/runner.js",
    "test:corpus": "tree-sitter test",
    "test:conformance": "node test/conformance/runner.js",
    "build-wasm": "tree-sitter build --wasm --output wasm/tree-sitter-mf2.wasm",
    "parse": "tree-sitter parse"
  },
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.0",
    "web-tree-sitter": "^0.24.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.24.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  }
}
